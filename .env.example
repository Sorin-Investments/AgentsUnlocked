# ============================================================
# AGENTS UNLOCKED — Environment Variables
# Copy this to .env.local for local dev
# Add all these as Environment Variables in Vercel dashboard
# ============================================================

# Supabase — get these from your Supabase project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key (secret)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...      # anon key (public, for dashboard)

# Event config (mirrors what's in the event_config table)
EVENT_ID=agents-unlocked-001

# Optional: for sending calendar invites via email
RESEND_API_KEY=re_...        # https://resend.com — free tier is enough
FROM_EMAIL=agents@sorin.vc
